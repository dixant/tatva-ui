{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationDir": "./dist/types"
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",
    "storybook-static",
    "**/*.test.tsx",
    "**/*.test.ts",
    "**/*.stories.tsx",
    "tests",
    ".storybook"
  ]
}
