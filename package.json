{
  "name": "@dixant/tatva-ui",
  "version": "0.1.0",
  "description": "A production-quality React + TypeScript design system built for enterprise applications",
  "keywords": [
    "react",
    "typescript",
    "ui",
    "component-library",
    "design-system",
    "tatva"
  ],
  "author": "Dixant Sharma",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dixant/tatva-ui.git"
  },
  "homepage": "https://github.com/dixant/tatva-ui#readme",
  "main": "./dist/tatva-ui.cjs.js",
  "module": "./dist/tatva-ui.es.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/tatva-ui.es.js",
      "require": "./dist/tatva-ui.cjs.js"
    },
    "./style.css": "./dist/style.css",
    "./themes/slate.css": "./dist/themes/slate.css",
    "./themes/rose.css": "./dist/themes/rose.css",
    "./themes/violet.css": "./dist/themes/violet.css",
    "./themes/emerald.css": "./dist/themes/emerald.css",
    "./themes/orange.css": "./dist/themes/orange.css",
    "./themes/index.css": "./dist/themes/index.css"
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "bin"
  ],
  "bin": {
    "tatva": "./bin/tatva.mjs",
    "tatva-ui": "./bin/tatva.mjs"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "tsc -p tsconfig.build.json && vite build && node scripts/copy-theme-presets.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --fix && prettier --write src/",
    "type-check": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build:registry": "node scripts/build-registry.mjs",
    "prepublishOnly": "npm run lint && npm run type-check && npm run test && npm run build && npm run build:registry"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@storybook/addon-a11y": "^8.3.0",
    "@storybook/addon-essentials": "^8.3.0",
    "@storybook/addon-links": "^8.3.0",
    "@storybook/react-vite": "^8.3.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.1.0",
    "axe-core": "^4.10.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-storybook": "^0.9.0",
    "globals": "^15.0.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^8.3.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.1.0"
  }
}
